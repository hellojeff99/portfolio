---
import { ArrowLeft, Printer } from "@lucide/astro";
import { getCollection, getEntry } from "astro:content";
import CertificationSection from "../components/resume/CertificationSection.astro";
import EducationSection from "../components/resume/EducationSection.astro";
import ProjectSection from "../components/resume/ProjectSection.astro";
import ResumeProfile from "../components/resume/ResumeProfile.astro";
import SkillsSection from "../components/resume/SkillsSection.astro";
import {
  compareProjectIds,
  getProjectCategory,
} from "../content/collections/projects";
import { resumeNavItems } from "../data/navigation";
import SiteLayout from "../layouts/SiteLayout.astro";

const profileEntry = await getEntry("profile", "profile");
const skillEntry = await getEntry("skills", "skills");
const educationEntry = await getEntry("educations", "educations");
const certificationEntry = await getEntry("certifications", "certifications");
const projectEntries = (await getCollection("projects")).sort((a, b) =>
  compareProjectIds(a.id, b.id),
);

if (!profileEntry) throw new Error("Profile content is required.");

const profile = profileEntry.data;
const bioParagraphs = profile.bio.split("\n").filter(Boolean);
const skills = skillEntry?.data.skills ?? [];
const educations = educationEntry?.data.educations ?? [];
const certifications = certificationEntry?.data.certifications ?? [];
const workProjects = projectEntries.filter(
  ({ id }) => getProjectCategory(id) === "work",
);
const selectedProjects = projectEntries
  .filter(({ id }) => {
    const category = getProjectCategory(id);
    return category === "featured" || category === "project";
  })
  .sort((first, second) => {
    const firstCategory = getProjectCategory(first.id);
    const secondCategory = getProjectCategory(second.id);
    const categoryOrder =
      Number(firstCategory === "project") -
      Number(secondCategory === "project");

    return categoryOrder || compareProjectIds(first.id, second.id);
  });
const activities = projectEntries.filter(
  ({ id }) => getProjectCategory(id) === "experience",
);
---

<SiteLayout
  title={`${profile.name} — Resume`}
  description={`${profile.name} ${profile.role} 이력서. ${bioParagraphs[0]}`}
  socialDescription={bioParagraphs[0]}
  themeColor="#ffffff"
  ogType="profile"
  ogImageAlt={`${profile.name} — ${profile.role}`}
  htmlClass="scroll-smooth bg-white motion-reduce:scroll-auto"
  htmlDataTheme="light"
  bodyClass="m-0 bg-white pt-16 font-sans text-slate-900 antialiased selection:bg-blue-600 selection:text-white print:bg-white print:pt-0"
  name={profile.name}
  githubUrl={profile.github}
  navItems={resumeNavItems}
  sidebarTitle="Resume"
  initialSidebarOpen
  activeSectionRatio={0.3}
  activeSectionFallback="first"
  headerPrintHidden
  layoutClass="md:gap-4 print:block print:p-0"
>
  <div slot="mobile-footer" class="mt-6 border-t border-slate-200 pt-5">
    <button
      class="inline-flex min-h-11 w-full cursor-pointer items-center justify-center gap-2 rounded-lg border border-blue-600 bg-blue-600 px-4 text-sm font-bold text-white shadow-sm transition-colors hover:border-blue-700 hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
      type="button"
      aria-label="PDF로 저장"
      data-print-resume
    >
      <Printer size={16} stroke-width={1.8} aria-hidden="true" />
      <span>PDF 저장</span>
    </button>
  </div>
  <div
    slot="sidebar-footer"
    class="mt-auto grid gap-2 border-t border-slate-200 px-1 pt-4"
  >
    <a
      class="inline-flex min-h-10 items-center justify-center gap-2 rounded-md border border-slate-200 bg-white px-3 text-xs font-semibold text-slate-700 transition-colors hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600"
      href="/"
    >
      <ArrowLeft size={15} stroke-width={1.8} aria-hidden="true" />
      <span>포트폴리오</span>
    </a>
    <button
      class="inline-flex min-h-10 cursor-pointer items-center justify-center gap-2 rounded-md border border-blue-600 bg-blue-600 px-3 text-xs font-bold text-white shadow-sm transition-colors hover:border-blue-700 hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
      type="button"
      aria-label="PDF로 저장"
      data-print-resume
    >
      <Printer size={15} stroke-width={1.8} aria-hidden="true" />
      <span>PDF 저장</span>
    </button>
  </div>

  <main
    class="mx-auto min-w-0 w-full max-w-4xl pt-2 pb-8 sm:pt-3 sm:pb-14 print:m-0 print:w-auto print:p-0"
    id="resume-content"
  >
    <article
      class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-8 print:rounded-none print:border-0 print:bg-transparent print:p-0 print:shadow-none"
    >
      <ResumeProfile profile={profile} />
      <EducationSection educations={educations} />
      <CertificationSection certifications={certifications} />
      <SkillsSection skills={skills} />
      <ProjectSection
        id="work"
        title="Work"
        projects={workProjects}
        compact
        subtitleBeforeTitle
      />
      <ProjectSection
        id="projects"
        title="Projects"
        projects={selectedProjects}
      />
      <ProjectSection
        id="experience"
        title="Experience"
        projects={activities}
      />
    </article>
  </main>

  <script>
    document
      .querySelectorAll<HTMLButtonElement>("[data-print-resume]")
      .forEach((button) =>
        button.addEventListener("click", () => window.print()),
      );
  </script>

  <style is:global>
    @page {
      size: A4 portrait;
      margin: 12mm 14mm;
    }

    @media print {
      html {
        font-size: 14px;
      }

      html,
      body {
        min-width: 0;
        width: 100%;
      }

      .resume-profile-header {
        grid-template-columns: 36mm minmax(0, 1fr) !important;
        column-gap: 14mm !important;
      }

      .resume-profile-photo {
        grid-column: auto !important;
        width: 36mm !important;
        max-width: none !important;
        height: 44mm !important;
      }

      .resume-profile-details {
        grid-column: auto !important;
        min-width: 0;
      }

      .resume-profile-details a span {
        overflow-wrap: anywhere;
      }

      .resume-flow-section {
        break-inside: auto;
      }

      .resume-flow-section > h2 {
        break-after: avoid-page;
      }
    }
  </style>
</SiteLayout>
