---
import { ArrowUpRight, CalendarDays, GitFork } from "@lucide/astro";
import {
  getCollection,
  getEntry,
  render,
  type CollectionEntry,
} from "astro:content";
import Header from "../../components/Header.astro";
import SkillItem from "../../components/SkillItem.astro";
import {
  getProjectCategory,
  getProjectSlug,
  type ProjectCategory,
} from "../../content/collections/projects";
import "../../styles/global.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects
    .filter(({ body }) => Boolean(body?.trim()))
    .map((project) => ({
      params: { id: getProjectSlug(project.id) },
      props: { project },
    }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const profileEntry = await getEntry("profile", "profile");

if (!profileEntry) throw new Error("Profile content is required.");

const profile = profileEntry.data;
const description =
  project.data.subtitle || `${project.data.title} 프로젝트 상세 내용`;
const repositoryUrl = project.data.github?.trim();
const categoryLabels: Record<ProjectCategory, string> = {
  work: "Work Experience",
  featured: "Featured Project",
  project: "Project",
  experience: "Experience",
};
const category = getProjectCategory(project.id);
const categoryLabel = categoryLabels[category];
const projectSlug = getProjectSlug(project.id);
const backLink =
  category === "work"
    ? { href: "/#experience", label: "경력 목록으로 돌아가기" }
    : { href: "/#projects", label: "프로젝트 목록으로 돌아가기" };
const tableOfContents = headings.filter(
  ({ depth }) => depth === 2 || depth === 3,
);
const projectNavItems = tableOfContents.map(({ slug, text }) => ({
  label: text,
  href: `#${slug}` as `#${string}`,
}));
const textFlowDefinitions = Array.from(
  (project.body ?? "").matchAll(/```text-flow[^\n]*\n([\s\S]*?)```/g),
  ([, definition]) => definition.trim(),
);
---

<!doctype html>
<html lang="ko" class="bg-slate-50">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f9fc" />
    <meta
      property="og:title"
      content={`${project.data.title} — ${profile.name}`}
    />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content="/og.png" />
    <meta
      property="og:image:alt"
      content={`${project.data.title} — ${profile.name}`}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={`${project.data.title} — ${profile.name}`}
    />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og.png" />
    <title>{project.data.title} — {profile.name}</title>
  </head>
  <body
    id="top"
    class="m-0 bg-slate-50 font-sans text-slate-900 antialiased selection:bg-blue-600 selection:text-white"
  >
    <a
      class="fixed left-3 top-2 z-[60] -translate-y-20 rounded-md bg-slate-950 px-4 py-2 text-sm font-bold text-white transition-transform focus:translate-y-0"
      href="#main-content"
    >
      본문으로 건너뛰기
    </a>

    <Header
      name={profile.name}
      githubUrl={profile.github}
      navItems={projectNavItems}
      showMenu={false}
      backHref={backLink.href}
      backLabel={backLink.label}
    />

    <main
      class="mx-auto w-full max-w-[96rem] px-4 pb-16 pt-[5.5rem] sm:px-6 sm:pb-24 sm:pt-24"
      id="main-content"
    >
      <div
        class="grid items-start gap-5 xl:grid-cols-[minmax(0,56rem)_15rem] xl:justify-center"
        data-content-layout
        data-sidebar-open="true"
      >
        <article
          class="mx-auto w-full max-w-4xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl xl:col-start-1"
        >
          <div class="min-w-0">
            <header
              class="relative isolate overflow-hidden border-b border-slate-200 px-5 py-7 sm:px-9 sm:py-9 lg:px-12 lg:py-10"
            >
              <div
                class="pointer-events-none absolute -right-16 -top-24 -z-10 size-72 rounded-full bg-blue-100/80 blur-3xl"
                aria-hidden="true"
              >
              </div>
              <div
                class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs font-bold uppercase tracking-widest text-blue-600"
              >
                <span>{categoryLabel}</span>
                <span
                  class="size-1 rounded-full bg-slate-300"
                  aria-hidden="true"></span>
                <span>{projectSlug}</span>
              </div>
              <h1
                class="mt-4 max-w-4xl break-keep text-3xl font-bold leading-tight tracking-tighter text-slate-950 sm:text-4xl lg:text-5xl"
              >
                {project.data.title}
              </h1>
              {
                project.data.subtitle && (
                  <p class="mt-3 max-w-3xl break-keep text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
                    {project.data.subtitle}
                  </p>
                )
              }
            </header>

            <aside
              class="border-b border-slate-200 bg-slate-50/70 px-5 py-7 sm:px-9 lg:px-12"
              aria-label="프로젝트 정보"
            >
              <div
                class="grid gap-7 sm:grid-cols-2 lg:grid-cols-[0.85fr_1.5fr_0.65fr]"
              >
                <section aria-labelledby="project-period-title">
                  <h2
                    class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-slate-500"
                    id="project-period-title"
                  >
                    Period
                  </h2>
                  <p
                    class="mt-3 flex items-start gap-2.5 text-sm font-semibold leading-6 text-slate-800"
                  >
                    <CalendarDays
                      class="mt-1 shrink-0 text-blue-600"
                      size={16}
                      stroke-width={1.8}
                      aria-hidden="true"
                    />
                    <span>{project.data.period}</span>
                  </p>
                </section>

                {
                  project.data.stack && (
                    <section aria-labelledby="project-stack-title">
                      <h2
                        class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-slate-500"
                        id="project-stack-title"
                      >
                        Tech Stack
                      </h2>
                      <ul class="mt-3 flex list-none flex-wrap gap-2 p-0">
                        {project.data.stack.map((item) => (
                          <SkillItem name={item} />
                        ))}
                      </ul>
                    </section>
                  )
                }

                {
                  repositoryUrl && (
                    <section aria-labelledby="project-repository-title">
                      <h2
                        class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-slate-500"
                        id="project-repository-title"
                      >
                        Repository
                      </h2>
                      <a
                        class="group mt-3 inline-flex min-h-10 items-center gap-2 rounded-md border border-slate-200 bg-white px-3 text-sm font-bold text-blue-600 shadow-sm transition duration-150 hover:-translate-y-0.5 hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 motion-reduce:transform-none"
                        href={repositoryUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${project.data.title} GitHub 저장소 새 탭에서 열기`}
                      >
                        <GitFork
                          size={16}
                          stroke-width={1.8}
                          aria-hidden="true"
                        />
                        <span>GitHub</span>
                        <ArrowUpRight
                          class="transition-transform duration-150 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 motion-reduce:transform-none"
                          size={13}
                          stroke-width={1.8}
                          aria-hidden="true"
                        />
                      </a>
                    </section>
                  )
                }
              </div>
            </aside>

            <div
              class="project-prose min-w-0 px-5 py-9 sm:px-9 sm:py-12 lg:px-12"
              data-text-flow-definitions={JSON.stringify(textFlowDefinitions)}
            >
              <Content />
            </div>
          </div>
        </article>

        {
          tableOfContents.length > 0 && (
            <nav
              class="sticky top-24 hidden max-h-[calc(100vh-7rem)] overflow-y-auto rounded-xl border border-slate-200 bg-white p-4 shadow-xl shadow-slate-900/10 xl:col-start-2 xl:row-start-1 xl:block"
              aria-labelledby="floating-project-toc-title"
              aria-hidden="false"
              data-desktop-sidebar
            >
              <h2
                class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-blue-600"
                id="floating-project-toc-title"
              >
                Contents
              </h2>
              <ol class="mt-3 grid list-none gap-1 border-l border-slate-200 p-0">
                {tableOfContents.map((heading) => (
                  <li class={heading.depth === 3 ? "pl-2.5" : ""}>
                    <a
                      class:list={[
                        "block border-l-2 border-transparent py-1.5 leading-snug text-slate-600 transition-colors hover:border-blue-500 hover:text-blue-700",
                        heading.depth === 3
                          ? "px-2.5 text-[0.72rem]"
                          : "px-2.5 text-xs font-semibold",
                      ]}
                      href={`#${heading.slug}`}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )
        }
      </div>
    </main>

    {
      tableOfContents.length > 0 && (
        <details
          class="group fixed bottom-4 right-4 z-40 xl:hidden"
          data-mobile-toc
        >
          <summary class="flex min-h-11 cursor-pointer list-none items-center rounded-lg border border-blue-600 bg-blue-600 px-4 text-sm font-bold text-white shadow-lg shadow-blue-600/20 transition-colors hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 [&::-webkit-details-marker]:hidden">
            목차
          </summary>
          <nav
            class="absolute bottom-full right-0 mb-2 max-h-[min(70vh,32rem)] w-[min(18rem,calc(100vw-2rem))] overflow-y-auto rounded-xl border border-slate-200 bg-white p-4 shadow-2xl shadow-slate-900/20"
            aria-label="프로젝트 목차"
          >
            <ol class="m-0 grid list-none gap-1 border-l border-slate-200 p-0">
              {tableOfContents.map((heading) => (
                <li class={heading.depth === 3 ? "pl-3" : ""}>
                  <a
                    class:list={[
                      "block border-l-2 border-transparent py-2 leading-snug text-slate-600 transition-colors hover:border-blue-500 hover:text-blue-700",
                      heading.depth === 3
                        ? "px-3 text-xs"
                        : "px-3 text-sm font-semibold",
                    ]}
                    href={`#${heading.slug}`}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      )
    }

    <footer class="border-t border-slate-200 bg-white">
      <div
        class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 py-7 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between sm:px-6"
      >
        <p class="m-0 font-mono text-xs">
          © {new Date().getFullYear()}
          {profile.name}
        </p>
        <nav class="flex items-center gap-4" aria-label="외부 링크">
          <a
            class="inline-flex items-center gap-1.5 font-semibold transition-colors hover:text-slate-900"
            href={profile.github}
            target="_blank"
            rel="noopener noreferrer"
          >
            <GitFork size={15} stroke-width={1.8} aria-hidden="true" />
            <span>GitHub</span>
          </a>
          <a
            class="font-semibold transition-colors hover:text-slate-900"
            href="/resume"
          >
            Resume
          </a>
        </nav>
      </div>
    </footer>

    <script>
      const siteHeader =
        document.querySelector<HTMLElement>("[data-site-header]");
      const headerMenu =
        document.querySelector<HTMLElement>("[data-mobile-menu]");
      const headerMenuToggle =
        document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
      const headerMenuBackdrop = document.querySelector<HTMLElement>(
        "[data-menu-backdrop]",
      );
      const headerMenuIcon =
        document.querySelector<SVGElement>("[data-menu-icon]");
      const headerCloseIcon =
        document.querySelector<SVGElement>("[data-close-icon]");
      const desktopSidebar = document.querySelector<HTMLElement>(
        "[data-desktop-sidebar]",
      );
      const contentLayout = document.querySelector<HTMLElement>(
        "[data-content-layout]",
      );
      const desktopTocMedia = matchMedia("(min-width: 1280px)");
      let desktopSidebarOpen = true;

      const updateHeaderMenuToggle = (open: boolean, label: string) => {
        if (!headerMenuToggle) return;
        headerMenuToggle.setAttribute("aria-expanded", String(open));
        headerMenuToggle.setAttribute("aria-label", label);
        headerMenuIcon?.classList.toggle("hidden", open);
        headerCloseIcon?.classList.toggle("hidden", !open);
      };

      const setHeaderMenuOpen = (open: boolean, updateToggle = true) => {
        if (!siteHeader || !headerMenu || !headerMenuToggle) return;
        siteHeader.dataset.menuOpen = String(open);
        headerMenu.setAttribute("aria-hidden", String(!open));
        headerMenu.classList.toggle("hidden", !open);
        headerMenuBackdrop?.setAttribute("aria-hidden", String(!open));
        headerMenuBackdrop?.classList.toggle("hidden", !open);
        document.body.classList.toggle("overflow-hidden", open);
        if (updateToggle) {
          updateHeaderMenuToggle(open, open ? "메뉴 닫기" : "메뉴 열기");
        }
      };

      const setDesktopSidebarOpen = (open: boolean) => {
        desktopSidebarOpen = open;
        if (desktopSidebar) {
          desktopSidebar.setAttribute("aria-hidden", String(!open));
          desktopSidebar.toggleAttribute("inert", !open);
          desktopSidebar.style.display = open ? "" : "none";
        }
        if (contentLayout) {
          contentLayout.dataset.sidebarOpen = String(open);
          contentLayout.style.gridTemplateColumns = open
            ? ""
            : "minmax(0, 1fr) 0rem";
          contentLayout.style.columnGap = open ? "" : "0rem";
        }
        updateHeaderMenuToggle(open, open ? "목차 닫기" : "목차 열기");
      };

      const resetDesktopSidebarStyles = () => {
        desktopSidebar?.setAttribute("aria-hidden", "false");
        desktopSidebar?.removeAttribute("inert");
        desktopSidebar?.style.removeProperty("display");
        if (contentLayout) {
          contentLayout.dataset.sidebarOpen = "true";
          contentLayout.style.removeProperty("grid-template-columns");
          contentLayout.style.removeProperty("column-gap");
        }
      };

      headerMenuToggle?.addEventListener("click", () => {
        if (desktopTocMedia.matches) {
          setDesktopSidebarOpen(!desktopSidebarOpen);
        } else {
          setHeaderMenuOpen(siteHeader?.dataset.menuOpen !== "true");
        }
      });
      headerMenuBackdrop?.addEventListener("click", () =>
        setHeaderMenuOpen(false),
      );
      headerMenu
        ?.querySelectorAll("a")
        .forEach((link) =>
          link.addEventListener("click", () => setHeaderMenuOpen(false)),
        );
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !desktopTocMedia.matches) {
          setHeaderMenuOpen(false);
        }
      });
      desktopTocMedia.addEventListener("change", (event) => {
        setHeaderMenuOpen(false, !event.matches);
        if (event.matches) setDesktopSidebarOpen(desktopSidebarOpen);
        else resetDesktopSidebarStyles();
      });

      if (desktopTocMedia.matches) {
        setDesktopSidebarOpen(desktopSidebarOpen);
      } else {
        resetDesktopSidebarStyles();
        setHeaderMenuOpen(false);
      }

      const renderTextFlows = () => {
        const projectProse =
          document.querySelector<HTMLElement>(".project-prose");
        const textFlowDefinitions = JSON.parse(
          projectProse?.dataset.textFlowDefinitions ?? "[]",
        ) as string[];
        const blocks = [
          ...document.querySelectorAll<HTMLPreElement>(
            '.project-prose pre[data-language="plaintext"]',
          ),
        ].filter((block) =>
          textFlowDefinitions.includes(block.textContent?.trim() ?? ""),
        );

        for (const block of blocks) {
          const definition = block.textContent?.trim();
          if (!definition) continue;

          const steps = definition.split(/\s*(?:→|->|=>)\s*/u).filter(Boolean);

          if (steps.length < 2) {
            block.classList.add("text-panel");
            continue;
          }

          const flow = document.createElement("figure");
          flow.className = "text-flow";
          flow.style.setProperty("--flow-step-count", String(steps.length));

          const list = document.createElement("ol");
          list.className = "text-flow__steps";

          for (const step of steps) {
            const item = document.createElement("li");

            const label = document.createElement("span");
            label.className = "text-flow__label";
            label.textContent = step;

            item.append(label);
            list.append(item);
          }

          flow.append(list);
          block.replaceWith(flow);
        }
      };

      const renderMermaidDiagrams = async () => {
        const blocks = [
          ...document.querySelectorAll<HTMLElement>(
            '.project-prose pre[data-language="mermaid"]',
          ),
        ];

        if (blocks.length === 0) return;

        const { default: mermaid } = await import("mermaid");

        mermaid.initialize({
          startOnLoad: false,
          securityLevel: "strict",
          theme: "base",
          themeVariables: {
            background: "#ffffff",
            primaryColor: "#eff6ff",
            primaryTextColor: "#0f172a",
            primaryBorderColor: "#60a5fa",
            lineColor: "#64748b",
            secondaryColor: "#f8fafc",
            tertiaryColor: "#ffffff",
            fontFamily:
              "Pretendard, Inter, ui-sans-serif, system-ui, sans-serif",
          },
          flowchart: {
            curve: "basis",
            htmlLabels: true,
          },
        });

        await document.fonts.ready;

        for (const [index, block] of blocks.entries()) {
          const definition = block.textContent?.trim();
          if (!definition) continue;

          try {
            const { svg, bindFunctions } = await mermaid.render(
              `project-mermaid-${index}`,
              definition,
            );
            const diagram = document.createElement("figure");
            diagram.className = "mermaid-diagram";
            diagram.setAttribute("role", "img");
            diagram.setAttribute(
              "aria-label",
              `프로젝트 구조 다이어그램 ${index + 1}`,
            );
            diagram.innerHTML = svg;
            block.replaceWith(diagram);
            bindFunctions?.(diagram);
          } catch (error) {
            block.classList.add("mermaid-render-error");
            console.error("Mermaid diagram rendering failed.", error);
          }
        }
      };

      renderTextFlows();

      const mermaidBlocks = [
        ...document.querySelectorAll<HTMLElement>(
          '.project-prose pre[data-language="mermaid"]',
        ),
      ];

      if (mermaidBlocks.length > 0) {
        if ("IntersectionObserver" in window) {
          const diagramObserver = new IntersectionObserver(
            (entries) => {
              if (!entries.some((entry) => entry.isIntersecting)) return;
              diagramObserver.disconnect();
              void renderMermaidDiagrams();
            },
            { rootMargin: "600px 0px" },
          );
          mermaidBlocks.forEach((block) => diagramObserver.observe(block));
        } else {
          void renderMermaidDiagrams();
        }
      }

      const mobileToc =
        document.querySelector<HTMLDetailsElement>("[data-mobile-toc]");

      mobileToc
        ?.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
        .forEach((link) => {
          link.addEventListener("click", () => {
            mobileToc.removeAttribute("open");
          });
        });
    </script>
  </body>
</html>

<style is:global>
  [data-menu-toggle] {
    visibility: hidden;
    pointer-events: none;
  }

  @media (min-width: 48rem) and (max-width: 79.999rem) {
    [data-mobile-menu][aria-hidden="false"],
    [data-menu-backdrop][aria-hidden="false"] {
      display: block;
    }
  }

  .project-prose {
    color: #475569;
    font-size: 0.975rem;
    line-height: 1.9;
    overflow-wrap: anywhere;
  }

  .project-prose > :first-child {
    margin-top: 0;
  }

  .project-prose > :last-child {
    margin-bottom: 0;
  }

  .project-prose h2 {
    scroll-margin-top: 6rem;
    margin: 2.7rem 0 1rem;
    color: #0f172a;
    font-size: 1.35rem;
    font-weight: 750;
    line-height: 1.4;
    letter-spacing: -0.025em;
  }

  .project-prose h2:first-child {
    margin-top: 0;
  }

  .project-prose h3 {
    scroll-margin-top: 6rem;
    margin: 2rem 0 0.75rem;
    color: #1e293b;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .project-prose p {
    margin: 0 0 1.25rem;
  }

  .project-prose ul,
  .project-prose ol {
    display: grid;
    gap: 0.55rem;
    margin: 0 0 1.5rem;
    padding-left: 1.3rem;
  }

  .project-prose li {
    padding-left: 0.2rem;
  }

  .project-prose li::marker {
    color: #3b82f6;
  }

  .project-prose strong {
    color: #1e293b;
    font-weight: 700;
  }

  .project-prose a {
    color: #2563eb;
    font-weight: 650;
    text-decoration: underline;
    text-decoration-color: #bfdbfe;
    text-underline-offset: 0.2em;
  }

  .project-prose code {
    border: 1px solid #e2e8f0;
    border-radius: 0.3rem;
    background: #f8fafc;
    padding: 0.15rem 0.35rem;
    color: #334155;
    font-size: 0.88em;
  }

  .project-prose pre code {
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .project-prose pre.text-panel {
    position: relative;
    margin: 1.5rem 0 2rem;
    overflow-x: auto;
    border: 1px solid #bfdbfe;
    border-radius: 0.85rem;
    background: linear-gradient(135deg, #f8fbff, #eff6ff) !important;
    padding: 2.75rem 1.125rem 1.125rem;
    color: #1e3a8a !important;
    font-size: 0.875rem;
    line-height: 1.75;
    white-space: pre-wrap;
    box-shadow: 0 14px 32px -26px rgb(37 99 235 / 0.45);
  }

  .project-prose pre.text-panel::before {
    content: "Text";
    position: absolute;
    top: 0.85rem;
    left: 1.125rem;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.65rem;
    font-weight: 750;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #2563eb;
  }

  .project-prose .text-flow {
    margin: 0.75rem 0 1rem;
    border: 1px solid #bfdbfe;
    border-radius: 0.9rem;
    background:
      radial-gradient(
        circle at 100% 0%,
        rgb(191 219 254 / 0.45),
        transparent 38%
      ),
