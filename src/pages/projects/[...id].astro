---
import { ArrowUpRight, CalendarDays, GitFork } from "@lucide/astro";
import {
  getCollection,
  getEntry,
  render,
  type CollectionEntry,
} from "astro:content";
import ProjectContent from "../../components/project-detail/ProjectContent.astro";
import ProjectTableOfContents from "../../components/project-detail/ProjectTableOfContents.astro";
import SkillItem from "../../components/SkillItem.astro";
import {
  getProjectCategory,
  getProjectSlug,
  type ProjectCategory,
} from "../../content/collections/projects";
import SiteLayout from "../../layouts/SiteLayout.astro";
import "../../styles/project-detail.css";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects
    .filter(({ body }) => Boolean(body?.trim()))
    .map((project) => ({
      params: { id: getProjectSlug(project.id) },
      props: { project },
    }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const profileEntry = await getEntry("profile", "profile");

if (!profileEntry) throw new Error("Profile content is required.");

const profile = profileEntry.data;
const description =
  project.data.subtitle || `${project.data.title} 프로젝트 상세 내용`;
const repositoryUrl = project.data.github?.trim();
const categoryLabels: Record<ProjectCategory, string> = {
  work: "Work Experience",
  featured: "Featured Project",
  project: "Project",
  experience: "Experience",
};
const category = getProjectCategory(project.id);
const categoryLabel = categoryLabels[category];
const projectSlug = getProjectSlug(project.id);
const backLink =
  category === "work"
    ? { href: "/#experience", label: "경력 목록으로 돌아가기" }
    : { href: "/#projects", label: "프로젝트 목록으로 돌아가기" };
const tableOfContents = headings.filter(
  ({ depth }) => depth === 2 || depth === 3,
);
const textFlowDefinitions = Array.from(
  (project.body ?? "").matchAll(/```text-flow[^\n]*\n([\s\S]*?)```/g),
  ([, definition]) => definition.trim(),
);
---

<SiteLayout
  variant="detail"
  title={`${project.data.title} — ${profile.name}`}
  description={description}
  ogType="article"
  ogImageAlt={`${project.data.title} — ${profile.name}`}
  htmlClass="bg-slate-50"
  bodyClass="m-0 bg-slate-50 font-sans text-slate-900 antialiased selection:bg-blue-600 selection:text-white"
  name={profile.name}
  githubUrl={profile.github}
  backHref={backLink.href}
  backLabel={backLink.label}
>
  <a
    class="fixed left-3 top-2 z-[60] -translate-y-20 rounded-md bg-slate-950 px-4 py-2 text-sm font-bold text-white transition-transform focus:translate-y-0"
    href="#main-content"
  >
    본문으로 건너뛰기
  </a>

  <main
    class="mx-auto w-full max-w-[96rem] px-4 pb-16 pt-[5.5rem] sm:px-6 sm:pb-24 sm:pt-24"
    id="main-content"
  >
    <div
      class="grid items-start gap-5 xl:grid-cols-[minmax(0,56rem)_15rem] xl:justify-center"
    >
      <article
        class="mx-auto w-full max-w-4xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl xl:col-start-1"
      >
        <div class="min-w-0">
          <header
            class="relative isolate overflow-hidden border-b border-slate-200 px-5 py-7 sm:px-9 sm:py-9 lg:px-12 lg:py-10"
          >
            <div
              class="pointer-events-none absolute -right-16 -top-24 -z-10 size-72 rounded-full bg-blue-100/80 blur-3xl"
              aria-hidden="true"
            >
            </div>
            <div
              class="flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs font-bold uppercase tracking-widest text-blue-600"
            >
              <span>{categoryLabel}</span>
              <span class="size-1 rounded-full bg-slate-300" aria-hidden="true"
              ></span>
              <span>{projectSlug}</span>
            </div>
            <h1
              class="mt-4 max-w-4xl break-keep text-3xl font-bold leading-tight tracking-tighter text-slate-950 sm:text-4xl lg:text-5xl"
            >
              {project.data.title}
            </h1>
            {
              project.data.subtitle && (
                <p class="mt-3 max-w-3xl break-keep text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
                  {project.data.subtitle}
                </p>
              )
            }
          </header>

          <aside
            class="border-b border-slate-200 bg-slate-50/70 px-5 py-7 sm:px-9 lg:px-12"
            aria-label="프로젝트 정보"
          >
            <div
              class="grid gap-7 sm:grid-cols-2 lg:grid-cols-[0.85fr_1.5fr_0.65fr]"
            >
              <section aria-labelledby="project-period-title">
                <h2
                  class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-slate-500"
                  id="project-period-title"
                >
                  Period
                </h2>
                <p
                  class="mt-3 flex items-start gap-2.5 text-sm font-semibold leading-6 text-slate-800"
                >
                  <CalendarDays
                    class="mt-1 shrink-0 text-blue-600"
                    size={16}
                    stroke-width={1.8}
                    aria-hidden="true"
                  />
                  <span>{project.data.period}</span>
                </p>
              </section>

              {
                project.data.stack && (
                  <section aria-labelledby="project-stack-title">
                    <h2
                      class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-slate-500"
                      id="project-stack-title"
                    >
                      Tech Stack
                    </h2>
                    <ul class="mt-3 flex list-none flex-wrap gap-2 p-0">
                      {project.data.stack.map((item) => (
                        <SkillItem name={item} />
                      ))}
                    </ul>
                  </section>
                )
              }

              {
                repositoryUrl && (
                  <section aria-labelledby="project-repository-title">
                    <h2
                      class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-slate-500"
                      id="project-repository-title"
                    >
                      Repository
                    </h2>
                    <a
                      class="group mt-3 inline-flex min-h-10 items-center gap-2 rounded-md border border-slate-200 bg-white px-3 text-sm font-bold text-blue-600 shadow-sm transition duration-150 hover:-translate-y-0.5 hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 motion-reduce:transform-none"
                      href={repositoryUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${project.data.title} GitHub 저장소 새 탭에서 열기`}
                    >
                      <GitFork
                        size={16}
                        stroke-width={1.8}
                        aria-hidden="true"
                      />
                      <span>GitHub</span>
                      <ArrowUpRight
                        class="transition-transform duration-150 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 motion-reduce:transform-none"
                        size={13}
                        stroke-width={1.8}
                        aria-hidden="true"
                      />
                    </a>
                  </section>
                )
              }
            </div>
          </aside>

          <ProjectContent textFlowDefinitions={textFlowDefinitions}>
            <Content />
          </ProjectContent>
        </div>
      </article>

      <ProjectTableOfContents headings={tableOfContents} variant="desktop" />
    </div>
  </main>

  <ProjectTableOfContents headings={tableOfContents} variant="mobile" />

  <footer class="border-t border-slate-200 bg-white">
    <div
      class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 py-7 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between sm:px-6"
    >
      <p class="m-0 font-mono text-xs">
        © {new Date().getFullYear()}
        {profile.name}
      </p>
      <nav class="flex items-center gap-4" aria-label="외부 링크">
        <a
          class="inline-flex items-center gap-1.5 font-semibold transition-colors hover:text-slate-900"
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
        >
          <GitFork size={15} stroke-width={1.8} aria-hidden="true" />
          <span>GitHub</span>
        </a>
        <a
          class="font-semibold transition-colors hover:text-slate-900"
          href="/resume"
        >
          Resume
        </a>
      </nav>
    </div>
  </footer>
</SiteLayout>
