---
import type { CollectionEntry } from "astro:content";

interface Props {
  educations: CollectionEntry<"educations">["data"]["educations"];
}

const { educations } = Astro.props;
---

<section
  class="scroll-mt-24 border-t border-slate-200 py-6 print:break-inside-avoid"
  id="education"
  data-nav-section
  aria-labelledby="education-title"
>
  <h2
    class="mb-4 text-xs font-bold uppercase tracking-widest text-slate-900"
    id="education-title"
  >
    Education
  </h2>
  <div class="grid gap-4">
    {
      educations.map((education) => (
        <article class="grid gap-2 sm:flex sm:items-baseline sm:justify-between sm:gap-7 print:break-inside-avoid">
          <div>
            <h3 class="m-0 text-sm font-bold tracking-tight text-slate-900">
              {education.school}
            </h3>
            {education.major && (
              <p class="mt-1 text-xs leading-normal text-slate-600">
                {education.major}
              </p>
            )}
            {education.sub && (
              <p class="mt-1 text-xs leading-normal text-slate-600">
                {education.sub}
              </p>
            )}
            {education.gpa && (
              <p class="mt-1 text-xs leading-normal text-slate-600">
                GPA {education.gpa}
              </p>
            )}
          </div>
          <time class="shrink-0 whitespace-nowrap text-xs text-slate-400">
            {education.period}
          </time>
        </article>
      ))
    }
  </div>
</section>
