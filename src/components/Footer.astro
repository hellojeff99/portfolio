---
import {
  ArrowUp,
  ArrowUpRight,
  FileText,
  GitFork,
  Link,
  Mail,
} from "@lucide/astro";

interface Props {
  name: string;
  email: string;
  githubUrl: string;
  linkedinUrl: string;
}

const { name, email, githubUrl, linkedinUrl } = Astro.props;
const year = new Date().getFullYear();
---

<footer
  id="contact"
  class="scroll-mt-24 py-4 pt-12 md:pt-14 lg:pt-16"
  data-nav-section
  aria-label="연락처 및 바로가기"
>
  <div
    class="relative isolate overflow-hidden rounded-2xl border border-slate-700/80 bg-[linear-gradient(135deg,#0f172a_0%,#111c35_55%,#172554_100%)] text-white shadow-[0_24px_70px_-32px_rgba(30,64,175,0.45)]"
  >
    <div
      class="pointer-events-none absolute -right-20 -top-28 -z-10 size-80 rounded-full bg-blue-500/20 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="grid gap-3 p-4 sm:p-5 lg:grid-cols-4 lg:p-6">
      <a
        class="group flex min-h-20 items-center justify-between rounded-xl border border-white/15 bg-white/[0.05] px-4 text-sm font-semibold text-slate-200 transition duration-200 hover:-translate-y-0.5 hover:border-blue-400/50 hover:bg-blue-500/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400 motion-reduce:transform-none"
        href={`mailto:${email}`}
        aria-label={`${email}로 이메일 보내기`}
      >
        <span class="flex min-w-0 items-center gap-2.5">
          <Mail
            class="shrink-0"
            size={17}
            stroke-width={1.8}
            aria-hidden="true"
          />
          <span>Email</span>
        </span>
        <ArrowUpRight
          class="text-slate-400 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-white motion-reduce:transform-none"
          size={14}
          stroke-width={1.8}
          aria-hidden="true"
        />
      </a>

      <nav
        class="grid gap-3 lg:col-span-3 lg:grid-cols-3"
        aria-label="이력서 및 외부 프로필"
      >
        <a
          class="group flex min-h-20 items-center justify-between rounded-xl border border-white/15 bg-white/[0.05] px-4 text-sm font-semibold text-slate-200 transition duration-200 hover:-translate-y-0.5 hover:border-blue-400/50 hover:bg-blue-500/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400 motion-reduce:transform-none"
          href="/resume"
        >
          <span class="flex items-center gap-2.5">
            <FileText size={17} stroke-width={1.8} aria-hidden="true" />
            <span>Resume</span>
          </span>
          <ArrowUpRight
            class="text-slate-400 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-white motion-reduce:transform-none"
            size={14}
            stroke-width={1.8}
            aria-hidden="true"
          />
        </a>
        <a
          class="group flex min-h-20 items-center justify-between rounded-xl border border-white/15 bg-white/[0.05] px-4 text-sm font-semibold text-slate-200 transition duration-200 hover:-translate-y-0.5 hover:border-blue-400/50 hover:bg-blue-500/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400 motion-reduce:transform-none"
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="flex items-center gap-2.5">
            <GitFork size={17} stroke-width={1.8} aria-hidden="true" />
            <span>GitHub</span>
          </span>
          <ArrowUpRight
            class="text-slate-400 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-white motion-reduce:transform-none"
            size={14}
            stroke-width={1.8}
            aria-hidden="true"
          />
        </a>
        <a
          class="group flex min-h-20 items-center justify-between rounded-xl border border-white/15 bg-white/[0.05] px-4 text-sm font-semibold text-slate-200 transition duration-200 hover:-translate-y-0.5 hover:border-blue-400/50 hover:bg-blue-500/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400 motion-reduce:transform-none"
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="flex items-center gap-2.5">
            <Link size={17} stroke-width={1.8} aria-hidden="true" />
            <span>LinkedIn</span>
          </span>
          <ArrowUpRight
            class="text-slate-400 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-white motion-reduce:transform-none"
            size={14}
            stroke-width={1.8}
            aria-hidden="true"
          />
        </a>
      </nav>
    </div>

    <div
      class="flex flex-col gap-4 border-t border-white/10 px-5 py-5 font-mono text-[0.68rem] text-slate-400 sm:flex-row sm:items-center sm:justify-between sm:px-7 lg:px-10"
    >
      <p class="m-0">© {year} {name}</p>
      <a
        class="group inline-flex min-h-10 w-fit items-center gap-2 rounded-lg border border-white/15 bg-white/[0.05] px-3.5 font-sans text-xs font-semibold text-slate-100 transition duration-150 hover:border-blue-400/50 hover:bg-blue-500/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400"
        href="#top"
        aria-label="페이지 최상단으로 이동"
      >
        <span>Back to top</span>
        <ArrowUp
          class="text-blue-300 transition-transform duration-200 group-hover:-translate-y-0.5 group-hover:text-blue-200 motion-reduce:transform-none"
          size={15}
          stroke-width={2}
          aria-hidden="true"
        />
      </a>
    </div>
  </div>
</footer>
