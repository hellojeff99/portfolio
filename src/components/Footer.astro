---
import { ArrowUp } from "@lucide/astro";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<footer class="px-4 py-6 sm:px-6 lg:px-8" aria-label="페이지 하단">
  <div
    class="flex flex-col gap-3 border-t border-slate-200 pt-5 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between"
  >
    <p class="m-0 font-mono">© {new Date().getFullYear()} {name}</p>
    <a
      class="group inline-flex min-h-10 w-fit items-center gap-2 rounded-lg px-3 font-semibold text-slate-600 transition-colors hover:bg-slate-100 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
      href="#top"
      aria-label="페이지 최상단으로 이동"
    >
      <span>Back to top</span>
      <ArrowUp
        class="transition-transform duration-200 group-hover:-translate-y-0.5 motion-reduce:transform-none"
        size={15}
        stroke-width={2}
        aria-hidden="true"
      />
    </a>
  </div>
</footer>
