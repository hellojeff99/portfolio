---
import { ArrowUpRight, FileText, GitFork, Link, Mail } from "@lucide/astro";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  email: string;
  githubUrl: string;
  linkedinUrl: string;
}

const { email, githubUrl, linkedinUrl } = Astro.props;
---

<section
  id="contact"
  class="scroll-mt-24 px-4 py-12 md:px-6 md:py-14 lg:px-8 lg:py-16"
  data-nav-section
  aria-labelledby="contact-title"
>
  <SectionHeading icon="contact" eyebrow="Contact" id="contact-title" />

  <div
    class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-7"
  >
    <div
      class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="mt-2 break-all font-mono text-sm text-slate-500">
          {email}
        </p>
      </div>

      <a
        class="group inline-flex min-h-11 w-fit shrink-0 items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 text-sm font-bold text-white shadow-sm shadow-blue-600/20 transition duration-150 hover:-translate-y-0.5 hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 motion-reduce:transform-none"
        href={`mailto:${email}`}
        aria-label={`${email}로 이메일 보내기`}
      >
        <Mail size={16} stroke-width={1.9} aria-hidden="true" />
        <span>이메일 보내기</span>
        <ArrowUpRight
          class="transition-transform duration-150 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 motion-reduce:transform-none"
          size={14}
          stroke-width={1.9}
          aria-hidden="true"
        />
      </a>
    </div>

    <nav
      class="mt-6 grid gap-2 border-t border-slate-200 pt-4 sm:grid-cols-3"
      aria-label="이력서 및 외부 프로필"
    >
      <a
        class="group flex min-h-11 items-center gap-2.5 rounded-lg px-3 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-50 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-inset"
        href="/resume"
      >
        <FileText size={16} stroke-width={1.8} aria-hidden="true" />
        <span>Resume</span>
        <ArrowUpRight
          class="ml-auto text-slate-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 motion-reduce:transform-none"
          size={13}
          stroke-width={1.8}
          aria-hidden="true"
        />
      </a>
      <a
        class="group flex min-h-11 items-center gap-2.5 rounded-lg px-3 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-50 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-inset"
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <GitFork size={16} stroke-width={1.8} aria-hidden="true" />
        <span>GitHub</span>
        <ArrowUpRight
          class="ml-auto text-slate-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 motion-reduce:transform-none"
          size={13}
          stroke-width={1.8}
          aria-hidden="true"
        />
      </a>
      <a
        class="group flex min-h-11 items-center gap-2.5 rounded-lg px-3 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-50 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-inset"
        href={linkedinUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Link size={16} stroke-width={1.8} aria-hidden="true" />
        <span>LinkedIn</span>
        <ArrowUpRight
          class="ml-auto text-slate-400 transition-transform duration-150 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 motion-reduce:transform-none"
          size={13}
          stroke-width={1.8}
          aria-hidden="true"
        />
      </a>
    </nav>
  </div>
</section>
