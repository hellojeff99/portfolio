---
import type { NavItem } from "../data/portfolio";

interface Props {
  navItems: NavItem[];
}

const { navItems } = Astro.props;
const sidebarItems = navItems;
---

<aside
  class="sticky top-16 hidden h-[calc(100vh-4rem)] self-start border-r border-slate-300 bg-white/60 md:block print:hidden"
  id="desktop-sidebar"
  data-desktop-sidebar
  aria-label="페이지 목차"
>
  <div class="flex h-full flex-col overflow-y-auto pb-6 pr-2 pt-6">
    <slot name="header" />
    <nav class="grid gap-1.5" aria-label="페이지 섹션">
      {
        sidebarItems.map((item) => (
          <a
            class="relative flex min-h-10 items-center gap-2.5 rounded-md pr-1 text-sm font-semibold leading-tight text-slate-700 transition-colors duration-150 hover:bg-slate-100 hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-blue-600"
            href={item.href}
            data-nav-link
          >
            <span
              class="h-5 w-1 shrink-0 rounded-full bg-transparent"
              data-nav-indicator
              aria-hidden="true"
            />
            <span class="min-w-0">{item.label}</span>
          </a>
        ))
      }
    </nav>
    <slot name="footer">
      <div
        class="mt-auto flex items-center gap-2 border-t border-slate-200 px-1 pt-4 font-mono text-xs font-medium tracking-wide text-slate-600"
      >
        <span
          class="relative inline-block size-2 shrink-0 rounded-full bg-emerald-600 ring-4 ring-emerald-100"
          aria-hidden="true"></span>
        <span>Available for work</span>
      </div>
    </slot>
  </div>
</aside>
