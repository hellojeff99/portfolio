---
import { ArrowUpRight, FileText, GitFork, Menu, X } from "@lucide/astro";
import type { NavItem } from "../data/portfolio";

interface Props {
  name: string;
  githubUrl: string;
  navItems: NavItem[];
}

const { name, githubUrl, navItems } = Astro.props;
---

<header
  class="fixed inset-x-0 top-0 z-50 h-16 border-b border-slate-200 bg-slate-50/90 backdrop-blur-xl"
  data-site-header
  data-menu-open="false"
>
  <div class="flex h-full w-full items-center justify-between px-4 md:px-6">
    <div class="flex items-center gap-1.5">
      <button
        class="inline-grid size-10 cursor-pointer place-items-center rounded-md border border-transparent bg-transparent text-slate-600 transition-colors duration-150 hover:border-slate-200 hover:bg-white hover:text-slate-900"
        type="button"
        data-menu-toggle
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-menu desktop-sidebar"
      >
        <Menu class="block" data-menu-icon size={20} stroke-width={1.8} />
        <X class="hidden" data-close-icon size={20} stroke-width={1.8} />
      </button>
      <a
        class="inline-flex min-h-10 items-center font-bold tracking-tight text-slate-900"
        href="#top"
        aria-label={`${name} — 페이지 최상단으로 이동`}
      >
        <span
          class="mr-2.5 inline-grid size-8 place-items-center rounded-md border border-slate-900 font-mono text-sm font-bold"
          aria-hidden="true">{name.charAt(0)}</span
        >
        <span class="text-base">{name}</span>
        <span class="text-sm font-medium text-slate-500" aria-hidden="true"
          >.dev</span
        >
      </a>
    </div>

    <nav class="hidden items-center gap-1.5 md:flex" aria-label="외부 링크">
      <a
        class="inline-flex min-h-10 items-center gap-1.5 rounded-md px-2.5 text-sm font-semibold text-slate-600 transition-colors duration-150 hover:bg-slate-100 hover:text-slate-900"
        href="/resume"
      >
        <FileText size={16} stroke-width={1.8} />
        <span>Resume</span>
      </a>
      <a
        class="inline-flex min-h-10 items-center gap-1.5 rounded-md px-2.5 text-sm font-semibold text-slate-600 transition-colors duration-150 hover:bg-slate-100 hover:text-slate-900"
        href={githubUrl}
        target="_blank"
        rel="noreferrer"
      >
        <GitFork size={16} stroke-width={1.8} />
        <span>GitHub</span>
        <ArrowUpRight class="text-slate-500" size={13} stroke-width={1.8} />
      </a>
    </nav>
  </div>

  <div
    class="fixed bottom-0 right-0 top-16 z-50 hidden w-80 max-w-full overflow-y-auto border-l border-slate-200 bg-white p-6 shadow-xl md:hidden"
    id="mobile-menu"
    data-mobile-menu
    aria-hidden="true"
  >
    <nav aria-label="모바일 페이지 메뉴">
      <p
        class="font-mono mb-4 text-xs font-bold uppercase tracking-widest text-slate-500"
      >
        On this page
      </p>
      <div class="grid gap-1">
        {
          navItems.map((item, index) => (
            <a
              class="grid min-h-12 grid-cols-4 items-center rounded-md px-3 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900"
              href={item.href}
              data-nav-link
            >
              <span
                class="col-span-1 font-mono text-xs tracking-wide text-slate-500"
                data-nav-index
              >
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="col-span-3">{item.label}</span>
            </a>
          ))
        }
      </div>
      <div class="mt-6 grid grid-cols-2 gap-2.5 border-t border-slate-200 pt-5">
        <a
          class="flex min-h-10 items-center justify-center gap-2 rounded-md border border-slate-200 text-xs font-semibold text-slate-600"
          href="/resume"
        >
          <FileText size={17} stroke-width={1.8} />
          <span>Resume</span>
        </a>
        <a
          class="flex min-h-10 items-center justify-center gap-2 rounded-md border border-slate-200 text-xs font-semibold text-slate-600"
          href={githubUrl}
          target="_blank"
          rel="noreferrer"
        >
          <GitFork size={17} stroke-width={1.8} />
          <span>GitHub</span>
          <ArrowUpRight size={14} stroke-width={1.8} />
        </a>
      </div>
    </nav>
  </div>
  <div
    class="fixed inset-x-0 bottom-0 top-16 z-40 hidden bg-slate-900/50 md:hidden"
    data-menu-backdrop
    aria-hidden="true"
  >
  </div>
</header>
