---
import {
  ArrowLeft,
  ArrowUpRight,
  FileText,
  GitFork,
  LayoutGrid,
  Menu,
  Terminal,
  X,
} from "@lucide/astro";
import type { NavItem } from "../data/portfolio";

interface Props {
  name: string;
  githubUrl: string;
  navItems: NavItem[];
  showMenu?: boolean;
  printHidden?: boolean;
  backHref?: string;
  backLabel?: string;
}

const {
  name,
  githubUrl,
  navItems,
  showMenu = true,
  printHidden = false,
  backHref,
  backLabel = "이전 페이지로 돌아가기",
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isPortfolioPage = pathname === "/" || pathname.startsWith("/projects/");
const isResumePage = pathname === "/resume";
const brandName = "hellojeff99";
const brandHref = pathname === "/" ? "#top" : "/";
const brandLabel =
  pathname === "/"
    ? `${brandName}.dev — ${name} 포트폴리오 페이지 최상단으로 이동`
    : `${brandName}.dev — ${name} 포트폴리오 홈으로 이동`;

const primaryLinkClass =
  "inline-flex min-h-9 items-center gap-1.5 rounded-lg px-3 font-mono text-sm font-bold transition duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-blue-700";
const activePrimaryLinkClass =
  "bg-white text-blue-700 shadow-lg shadow-blue-950/15 hover:bg-blue-50";
const inactivePrimaryLinkClass =
  "text-blue-50 hover:bg-white/15 hover:text-white";
const mobilePrimaryLinkClass =
  "flex min-h-11 items-center justify-center gap-2 rounded-lg border text-xs font-bold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2";
---

<header
  class:list={[
    "fixed inset-x-0 top-0 z-50 isolate h-16 bg-blue-700",
    { "print:hidden": printHidden },
  ]}
  data-site-header
  data-menu-open="false"
>
  <div
    class="relative z-10 flex h-full w-full items-center justify-start gap-3 px-4 md:px-6"
  >
    <div class="flex min-w-0 items-center gap-1.5">
      {
        backHref && (
          <a
            class="inline-grid size-9 shrink-0 place-items-center rounded-lg border border-white/50 bg-white text-blue-700 shadow-sm transition duration-150 hover:-translate-x-0.5 hover:border-white/30 hover:bg-black/15 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-blue-700 motion-reduce:transform-none"
            href={backHref}
            aria-label={backLabel}
            title={backLabel}
          >
            <ArrowLeft size={17} stroke-width={2} aria-hidden="true" />
          </a>
        )
      }
      {
        showMenu && (
          <button
            class="inline-grid size-10 shrink-0 cursor-pointer place-items-center rounded-lg border border-transparent bg-transparent text-white/85 transition duration-150 hover:border-white/30 hover:bg-white/15 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-blue-700"
            type="button"
            data-menu-toggle
            aria-label="메뉴 열기"
            aria-expanded="false"
            aria-controls="mobile-menu desktop-sidebar"
          >
            <Menu class="block" data-menu-icon size={20} stroke-width={2.4} />
            <X class="hidden" data-close-icon size={20} stroke-width={2.4} />
          </button>
        )
      }
      <a
        class="group ml-0.5 inline-flex min-h-10 min-w-0 items-center rounded-lg font-mono font-bold tracking-tight text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-blue-700"
        href={brandHref}
        aria-label={brandLabel}
      >
        <span
          class="mr-2.5 inline-grid size-8 shrink-0 place-items-center rounded-lg border border-white/25 bg-black/20 text-white shadow-sm shadow-blue-950/15 transition duration-150 group-hover:-rotate-3 group-hover:bg-black/30 motion-reduce:transform-none"
          aria-hidden="true"
        >
          <Terminal size={17} stroke-width={2.1} />
        </span>
        <span class="truncate text-base">{brandName}</span>
        <span class="text-sm font-medium text-blue-100" aria-hidden="true"
          >.dev</span
        >
        <span
          class="ml-2 hidden size-1.5 shrink-0 rounded-full bg-cyan-200 shadow-[0_0_0.6rem_rgba(165,243,252,0.75)] sm:block"
          aria-hidden="true"></span>
      </a>
    </div>

    <nav class="hidden items-center gap-1 md:flex" aria-label="주요 링크">
      <a
        class:list={[
          primaryLinkClass,
          isPortfolioPage ? activePrimaryLinkClass : inactivePrimaryLinkClass,
        ]}
        href="/"
        aria-current={isPortfolioPage ? "page" : undefined}
      >
        <LayoutGrid size={16} stroke-width={1.8} aria-hidden="true" />
        <span>Portfolio</span>
      </a>
      <a
        class:list={[
          primaryLinkClass,
          isResumePage ? activePrimaryLinkClass : inactivePrimaryLinkClass,
        ]}
        href="/resume"
        aria-current={isResumePage ? "page" : undefined}
      >
        <FileText size={16} stroke-width={1.8} aria-hidden="true" />
        <span>Resume</span>
      </a>
      <span class="mx-0.5 h-5 w-px bg-white/20" aria-hidden="true"></span>
      <a
        class:list={[primaryLinkClass, inactivePrimaryLinkClass]}
        href={githubUrl}
        target="_blank"
        rel="noreferrer"
      >
        <GitFork size={16} stroke-width={1.8} aria-hidden="true" />
        <span>GitHub</span>
        <ArrowUpRight
          class="text-blue-100"
          size={13}
          stroke-width={1.8}
          aria-hidden="true"
        />
      </a>
    </nav>
  </div>

  {
    showMenu && (
      <>
        <div
          class="fixed left-0 top-16 z-50 hidden h-[calc(100vh-4rem)] w-80 max-w-[calc(100vw-2.5rem)] overscroll-contain border-r border-r-blue-200 border-t-2 border-t-blue-600 bg-white/98 p-5 shadow-2xl shadow-blue-950/20 md:hidden"
          id="mobile-menu"
          data-mobile-menu
          role="dialog"
          aria-label="사이트 메뉴"
          aria-hidden="true"
        >
          <nav aria-label="모바일 페이지 메뉴">
            <p class="font-mono mb-3 text-[0.68rem] font-bold uppercase tracking-[0.18em] text-blue-700">
              Navigate
            </p>
            <div class="grid grid-cols-2 gap-2">
              <a
                class:list={[
                  mobilePrimaryLinkClass,
                  isPortfolioPage
                    ? "border-blue-600 bg-blue-600 text-white shadow-sm shadow-blue-600/20"
                    : "border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50",
                ]}
                href="/"
                aria-current={isPortfolioPage ? "page" : undefined}
              >
                <LayoutGrid size={17} stroke-width={1.8} aria-hidden="true" />
                <span>Portfolio</span>
              </a>
              <a
                class:list={[
                  mobilePrimaryLinkClass,
                  isResumePage
                    ? "border-blue-600 bg-blue-600 text-white shadow-sm shadow-blue-600/20"
                    : "border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50",
                ]}
                href="/resume"
                aria-current={isResumePage ? "page" : undefined}
              >
                <FileText size={17} stroke-width={1.8} aria-hidden="true" />
                <span>Resume</span>
              </a>
              <a
                class:list={[
                  mobilePrimaryLinkClass,
                  "col-span-2 border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50",
                ]}
                href={githubUrl}
                target="_blank"
                rel="noreferrer"
              >
                <GitFork size={17} stroke-width={1.8} aria-hidden="true" />
                <span>GitHub</span>
                <ArrowUpRight
                  class="text-slate-400"
                  size={13}
                  stroke-width={1.8}
                  aria-hidden="true"
                />
              </a>
            </div>

            {navItems.length > 0 && (
              <div class="mt-6 border-t border-slate-200 pt-5">
                <p class="font-mono mb-3 text-[0.68rem] font-bold uppercase tracking-[0.18em] text-blue-700">
                  On this page
                </p>
                <div class="grid gap-1">
                  {navItems.map((item, index) => (
                    <a
                      class="grid min-h-11 grid-cols-[2.75rem_1fr] items-center rounded-lg px-3 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-inset"
                      href={item.href}
                      data-nav-link
                    >
                      <span
                        class="font-mono text-xs tracking-wide text-slate-500"
                        data-nav-index
                      >
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span>{item.label}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
            <slot name="mobile-footer" />
          </nav>
        </div>
        <div
          class="fixed inset-x-0 top-16 z-40 hidden h-[calc(100vh-4rem)] bg-blue-950/55 backdrop-blur-[2px] md:hidden"
          data-menu-backdrop
          aria-hidden="true"
        />
      </>
    )
  }
</header>
