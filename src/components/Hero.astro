---
import { FileText, Mail } from "@lucide/astro";

interface Props {
  role: string;
  email: string;
  location: string;
}

const { role, email, location } = Astro.props;
---

<section
  id="hero"
  class="relative flex scroll-mt-24 items-center py-8 md:py-12"
  data-nav-section
  aria-labelledby="hero-title"
>
  <div
    class="flex min-h-[calc(100svh-8rem)] w-full flex-col overflow-hidden rounded-2xl border border-slate-300 bg-white md:min-h-[calc(100svh-10rem)]"
  >
    <div
      class="flex h-12 shrink-0 items-center justify-between gap-4 border-b border-slate-300 bg-slate-500 px-4 sm:px-5"
    >
      <span class="flex items-center gap-1.5" aria-hidden="true">
        <span class="size-2.5 rounded-full bg-red-500"></span>
        <span class="size-2.5 rounded-full bg-amber-400"></span>
        <span class="size-2.5 rounded-full bg-emerald-500"></span>
      </span>
      <span
        class="font-mono truncate text-[0.65rem] font-bold uppercase tracking-[0.16em] text-slate-100"
      >
        {role}
      </span>
    </div>

    <div class="grid min-w-0 flex-1 grid-rows-[minmax(0,1fr)_auto]">
      <div class="flex min-w-0 items-center p-6 sm:p-10 lg:p-14 xl:p-20">
        <div class="max-w-5xl">
          <p
            class="hero-label-enter font-mono mb-7 text-xs font-bold uppercase tracking-[0.16em] text-blue-600"
          >
            {role}
          </p>

          <h1
            class="hero-text-enter m-0 break-normal text-3xl font-bold leading-[1.2] tracking-tighter text-slate-950 sm:break-keep sm:text-4xl md:text-5xl xl:text-6xl"
            id="hero-title"
          >
            데이터 흐름을 추적해 문제의 원인을 분석하고,
            <span class="text-blue-600">정합성·성능·유지보수성</span>을 고려한
            개발을 지향합니다.
          </h1>

          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a
              class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-slate-300 bg-white px-5 text-sm font-bold text-slate-800 shadow-md shadow-slate-900/10 transition duration-200 hover:-translate-y-0.5 hover:border-slate-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 motion-reduce:transform-none"
              href="/resume"
            >
              <span
                class="inline-grid size-7 place-items-center rounded-full bg-blue-600 text-white"
                aria-hidden="true"
              >
                <FileText size={14} stroke-width={1.8} />
              </span>
              <span>이력서 보기</span>
            </a>
            <a
              class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-slate-300 bg-white px-5 text-sm font-bold text-slate-800 shadow-md shadow-slate-900/10 transition duration-200 hover:-translate-y-0.5 hover:border-slate-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 motion-reduce:transform-none"
              href={`mailto:${email}`}
            >
              <span
                class="inline-grid size-7 place-items-center rounded-full bg-blue-600 text-white"
                aria-hidden="true"
              >
                <Mail size={14} stroke-width={1.8} />
              </span>
              <span>이메일 보내기</span>
            </a>
          </div>
        </div>
      </div>

      <aside
        class="flex items-center border-t border-slate-300 px-6 py-5 sm:px-8 sm:py-6"
        aria-label="프로필 명령어"
      >
        <dl class="grid w-full gap-3 sm:grid-cols-3">
          <div
            class="min-w-0 rounded-lg border border-slate-300 border-t-2 border-t-blue-600 p-4 shadow-sm"
          >
            <dt class="font-mono flex items-center gap-2 text-xs font-semibold">
              <span class="text-blue-600">$</span>
              <span class="text-emerald-600">echo</span>
              <span class="text-amber-600">$ROLE</span>
            </dt>
            <dd
              class="mt-3 grid grid-cols-[auto_1fr] gap-2 break-words font-mono text-sm font-bold text-slate-900"
            >
              <span class="text-blue-600" aria-hidden="true">&gt;</span>
              <span>{role}</span>
            </dd>
          </div>

          <div
            class="min-w-0 rounded-lg border border-slate-300 border-t-2 border-t-blue-600 p-4 shadow-sm"
          >
            <dt class="font-mono flex items-center gap-2 text-xs font-semibold">
              <span class="text-blue-600">$</span>
              <span class="text-emerald-600">echo</span>
              <span class="text-amber-600">$LOCATION</span>
            </dt>
            <dd
              class="mt-3 grid grid-cols-[auto_1fr] gap-2 break-words font-mono text-sm font-bold text-slate-900"
            >
              <span class="text-blue-600" aria-hidden="true">&gt;</span>
              <span>{location}</span>
            </dd>
          </div>

          <div
            class="min-w-0 rounded-lg border border-slate-300 border-t-2 border-t-blue-600 p-4 shadow-sm"
          >
            <dt class="font-mono flex items-center gap-2 text-xs font-semibold">
              <span class="text-blue-600">$</span>
              <span class="text-emerald-600">echo</span>
              <span class="text-amber-600">$EMAIL</span>
            </dt>
            <dd
              class="mt-3 grid min-w-0 grid-cols-[auto_1fr] gap-2 font-mono text-sm font-bold"
            >
              <span class="text-blue-600" aria-hidden="true">&gt;</span>
              <a
                class="min-w-0 break-all text-slate-900 transition-colors hover:text-blue-600"
                href={`mailto:${email}`}
              >
                {email}
              </a>
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .hero-label-enter {
      animation: hero-label-reveal 1100ms ease-out both;
    }

    .hero-text-enter {
      animation: hero-text-focus 1600ms cubic-bezier(0.16, 1, 0.3, 1) 160ms both;
    }
  }

  @keyframes hero-label-reveal {
    from {
      opacity: 0;
      letter-spacing: 0.32em;
    }

    to {
      opacity: 1;
      letter-spacing: 0.16em;
    }
  }

  @keyframes hero-text-focus {
    from {
      opacity: 0;
      filter: blur(0.6rem);
      transform: scale(0.985);
    }

    to {
      opacity: 1;
      filter: blur(0);
      transform: scale(1);
    }
  }
</style>
