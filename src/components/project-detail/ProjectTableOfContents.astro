---
interface TableOfContentsHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TableOfContentsHeading[];
  variant: "desktop" | "mobile";
}

const { headings, variant } = Astro.props;
---

{
  headings.length > 0 && variant === "desktop" && (
    <nav
      class="sticky top-24 hidden max-h-[calc(100vh-7rem)] overflow-y-auto rounded-xl border border-slate-200 bg-white p-4 shadow-xl shadow-slate-900/10 xl:col-start-2 xl:row-start-1 xl:block"
      aria-labelledby="floating-project-toc-title"
      data-desktop-sidebar
    >
      <h2
        class="font-mono m-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-blue-600"
        id="floating-project-toc-title"
      >
        Contents
      </h2>
      <ol class="mt-3 grid list-none gap-1 border-l border-slate-200 p-0">
        {headings.map((heading) => (
          <li class={heading.depth === 3 ? "pl-2.5" : ""}>
            <a
              class:list={[
                "block border-l-2 border-transparent py-1.5 leading-snug text-slate-600 transition-colors hover:border-blue-500 hover:text-blue-700",
                heading.depth === 3
                  ? "px-2.5 text-[0.72rem]"
                  : "px-2.5 text-xs font-semibold",
              ]}
              href={`#${heading.slug}`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

{
  headings.length > 0 && variant === "mobile" && (
    <details
      class="group fixed bottom-4 right-4 z-40 xl:hidden"
      data-mobile-toc
    >
      <summary class="flex min-h-11 cursor-pointer list-none items-center rounded-lg border border-blue-600 bg-blue-600 px-4 text-sm font-bold text-white shadow-lg shadow-blue-600/20 transition-colors hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 [&::-webkit-details-marker]:hidden">
        목차
      </summary>
      <nav
        class="absolute bottom-full right-0 mb-2 max-h-[min(70vh,32rem)] w-[min(18rem,calc(100vw-2rem))] overflow-y-auto rounded-xl border border-slate-200 bg-white p-4 shadow-2xl shadow-slate-900/20"
        aria-label="프로젝트 목차"
      >
        <ol class="m-0 grid list-none gap-1 border-l border-slate-200 p-0">
          {headings.map((heading) => (
            <li class={heading.depth === 3 ? "pl-3" : ""}>
              <a
                class:list={[
                  "block border-l-2 border-transparent py-2 leading-snug text-slate-600 transition-colors hover:border-blue-500 hover:text-blue-700",
                  heading.depth === 3
                    ? "px-3 text-xs"
                    : "px-3 text-sm font-semibold",
                ]}
                href={`#${heading.slug}`}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </details>
  )
}

<script>
  const mobileTocElements =
    document.querySelectorAll<HTMLDetailsElement>("[data-mobile-toc]");

  for (const mobileToc of mobileTocElements) {
    mobileToc
      .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
      .forEach((link) => {
        link.addEventListener("click", () => {
          mobileToc.removeAttribute("open");
        });
      });
  }
</script>
